#!/usr/bin/expect -f

source [file join [file dirname [info script]] common.tcl]

set timeout 60

if {$argc < 2} {
  puts "usage: natural_composite_execute_and_verify_artifacts.exp <workdir> <run_id>"
  exit 2
}

set workdir [lindex $argv 0]
set run_id [lindex $argv 1]
set query "지금 논문을 모두 삭제하고 최근 5년의 논문을 관련도순으로 pdf 있는 것들만 가져와줘"
set expected_step1 "Clear collect_papers artifacts"
set expected_step2 "Collect papers \\(lastYears=5, openAccess=true\\)"

spawn_autolabos $workdir

expect_app_ready

send -- "$query\r"
expect {
  -re "Natural query: $query" {}
  timeout { fail "FAIL: natural query log not found" }
}

expect {
  -re "Execution plan detected\\. Pending 2-step plan:" {}
  timeout { fail "FAIL: execution plan banner not found" }
}

expect {
  -re $expected_step1 {}
  timeout { fail "FAIL: first pending step not found" }
}

expect {
  -re $expected_step2 {}
  timeout { fail "FAIL: second pending step not found" }
}

send -- "y\r"
expect {
  -re "Confirmed\\. Running step 1/2\\." {}
  timeout { fail "FAIL: step 1 confirmation log not found" }
}

expect {
  -re "Cleared collect_papers artifacts:" {}
  timeout { fail "FAIL: clear step completion log not found" }
}

expect {
  -re "Next plan step ready \\(2/2\\): $expected_step2" {}
  timeout { fail "FAIL: next-step prompt not found" }
}

send -- "y\r"

expect {
  -re "Confirmed\\. Running step 2/2\\." {}
  timeout { fail "FAIL: step 2 confirmation log not found" }
}

expect {
  -re "collect_papers finished:" {}
  timeout { fail "FAIL: collect completion log not found" }
}

send -- "/quit\r"
expect {
  -re "Bye" {}
  timeout { fail "FAIL: quit did not complete" }
}

expect eof
puts "PASS: composite natural query executed sequential clear + collect"
