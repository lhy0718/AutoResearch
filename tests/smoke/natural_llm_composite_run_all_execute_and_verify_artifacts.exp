#!/usr/bin/expect -f

source [file join [file dirname [info script]] common.tcl]

set timeout 60

if {$argc < 2} {
  puts "usage: natural_llm_composite_run_all_execute_and_verify_artifacts.exp <workdir> <run_id>"
  exit 2
}

set workdir [lindex $argv 0]
set run_id [lindex $argv 1]
set query "Please refresh the library: wipe existing items, then repopulate it with open-access studies from the last five years ranked by relevance."
set expected_step1 "/agent clear collect_papers $run_id"
set expected_step2 "/agent collect --last-years 5 --sort relevance --open-access --run $run_id"

spawn_autolabos $workdir

expect_app_ready

send -- "$query\r"
expect {
  -re "Natural query: $query" {}
  timeout { fail "FAIL: natural query log not found" }
}

set escaped_step1 [escape_regex $expected_step1]
set escaped_step2 [escape_regex $expected_step2]

expect {
  -re "Execution plan detected\\. Pending 2-step plan:" {}
  timeout { fail "FAIL: llm execution plan banner not found" }
}

expect {
  -re $escaped_step1 {}
  timeout { fail "FAIL: llm first pending step not found" }
}

expect {
  -re $escaped_step2 {}
  timeout { fail "FAIL: llm second pending step not found" }
}

send -- "a\r"
expect {
  -re "Confirmed\\. Running all remaining steps from 1/2\\." {}
  timeout { fail "FAIL: llm run-all confirmation log not found" }
}

expect {
  -re "Step 1/2 completed\\." {}
  timeout { fail "FAIL: llm step 1 completion log not found" }
}

expect {
  -re "collect_papers finished:" {}
  timeout { fail "FAIL: llm collect completion log not found" }
}

expect {
  -re "Plan completed after 2 step\\(s\\)\\." {}
  timeout { fail "FAIL: llm final plan completion log not found" }
}

send -- "/quit\r"
expect {
  -re "Bye" {}
  timeout { fail "FAIL: quit did not complete" }
}

expect eof
puts "PASS: llm composite natural query executed with run-all approval"
